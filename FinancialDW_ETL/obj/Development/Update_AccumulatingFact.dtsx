      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{381D4EA9-0320-4456-AA37-E963638FAFEF}"
          SQLTask:SqlStatementSource="UPDATE f&#xA;&#xA;SET &#xA;   &#xA;       f.accm_txn_complete_time = v.complete_time,&#xA;           f.txn_process_time_hours = DATEDIFF(HOUR,        f.accm_txn_create_time, v.complete_time)&#xA;&#xA;FROM FactTransaction f&#xA;&#xA;JOIN (VALUES &#xA;   &#xA;    ('7661688', CAST('2026-04-02 22:20:21.463' AS DATETIME)),&#xA;        ('7766832', CAST('2026-03-29 22:20:21.463' AS DATETIME)),&#xA;        ('7614276', CAST('2026-03-31 22:20:21.463' AS DATETIME)),&#xA;        ('7825558', CAST('2026-04-02 22:20:21.463' AS DATETIME)),&#xA;        ('8112022', CAST('2026-04-01 22:20:21.463' AS DATETIME)),&#xA;        ('8134329', CAST('2026-04-02 22:20:21.463' AS DATETIME)),&#xA;        ('8127094', CAST('2026-04-01 22:20:21.463' AS DATETIME)),&#xA;        ('8194016', CAST('2026-04-01 22:20:21.463' AS DATETIME)),&#xA;        ('7582194', CAST('2026-03-30 22:20:21.463' AS DATETIME)),&#xA;        ('7921554', CAST('2026-03-31 22:20:21.463' AS DATETIME))&#xA;&#xA;) AS v(transaction_id, complete_time)&#xA;&#xA;ON f.transaction_id = v.transaction_id" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
