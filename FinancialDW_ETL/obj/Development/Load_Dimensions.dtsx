  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Load DimCard"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{A293FC1C-8A98-4337-ABCE-5FA1FB1D9B02}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DimCard"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{381D4EA9-0320-4456-AA37-E963638FAFEF}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE DimCard;&#xA;INSERT INTO DimCard (card_id, customer_id, card_brand, card_type,&#xA;    credit_limit, expires, has_chip, acct_open_date, &#xA;    year_pin_last_changed, card_on_dark_web)&#xA;&#xA;SELECT&#xA;   &#xA;         CAST(TRIM(id) AS INT), CAST(TRIM(client_id) AS INT),&#xA;         TRIM(card_brand), TRIM(card_type),&#xA;    &#xA;         TRY_CAST(REPLACE(REPLACE(TRIM(credit_limit),'$',''),',','') AS DECIMAL(12,2)),&#xA;    &#xA;        TRIM(expires), &#xA;        TRIM(has_chip), &#xA;         TRIM(acct_open_date),&#xA;         TRY_CAST(TRIM(year_pin_last_changed) AS INT), &#xA;         TRIM(card_on_dark_web)&#xA;&#xA;FROM FinancialStaging.dbo.stg_cards;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load DimCustomer"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{55A2165B-9F6D-43BF-A0F5-293F9277E3E9}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DimCustomer"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{381D4EA9-0320-4456-AA37-E963638FAFEF}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE DimCustomer;&#xA;INSERT INTO DimCustomer (customer_id, gender, current_age, birth_year,&#xA;    address, latitude, longitude, per_capita_income, yearly_income,&#xA;    total_debt, credit_score, num_credit_cards, eff_start_date, eff_end_date, is_current)&#xA;SELECT&#xA;    &#xA;          CAST(TRIM(id) AS INT), TRIM(gender), &#xA;          CAST(TRIM(current_age) AS INT),&#xA;    &#xA;          CAST(TRIM(birth_year) AS INT), &#xA;          TRIM(address),&#xA;    &#xA;          TRY_CAST(TRIM(latitude) AS DECIMAL(9,6)),&#xA;          TRY_CAST(TRIM(longitude) AS DECIMAL(9,6)),&#xA;          TRY_CAST(REPLACE(REPLACE(TRIM(per_capita_income),'$',''),',','') AS DECIMAL(12,2)),&#xA;           TRY_CAST(REPLACE(REPLACE(TRIM(yearly_income),'$',''),',','') AS DECIMAL(12,2)),&#xA;    &#xA;          TRY_CAST(REPLACE(REPLACE(TRIM(total_debt),'$',''),',','') AS DECIMAL(12,2)),&#xA;    &#xA;          CAST(TRIM(credit_score) AS INT), &#xA;          CAST(TRIM(num_credit_cards) AS INT),&#xA;    &#xA;          CAST(GETDATE() AS DATE), NULL, 1&#xA;&#xA;FROM FinancialStaging.dbo.stg_users;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load DimDate"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{87B8C18A-308E-47A1-9C19-9E7D440B8950}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DimDate"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{381D4EA9-0320-4456-AA37-E963638FAFEF}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE DimDate;&#xA;DECLARE @StartDate DATE = '2010-01-01'&#xA;&#xA;DECLARE @EndDate DATE = '2019-12-31'&#xA;&#xA;&#xA;WHILE @StartDate &lt;= @EndDate&#xA;&#xA;BEGIN&#xA;   &#xA;        INSERT INTO DimDate &#xA;    &#xA;        SELECT&#xA;        &#xA;                CAST(CONVERT(VARCHAR, @StartDate, 112) AS INT),&#xA;        &#xA;                @StartDate,&#xA;       &#xA;                 YEAR(@StartDate),&#xA;        &#xA;                 DATEPART(QUARTER, @StartDate),&#xA;        &#xA;                 MONTH(@StartDate),&#xA;       &#xA;                 DATENAME(MONTH, @StartDate),&#xA;        &#xA;                 DAY(@StartDate),&#xA;       &#xA;                 DATEPART(WEEKDAY, @StartDate),&#xA;                         DATENAME(WEEKDAY, @StartDate),&#xA;        &#xA;                 CASE WHEN DATEPART(WEEKDAY, @StartDate) IN (1,7) &#xA;             &#xA;                             THEN 1 ELSE 0 END&#xA;    &#xA;      SET @StartDate = DATEADD(DAY, 1, @StartDate)&#xA;&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load DimMCC"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{3EFA2E25-BA60-417E-BEE3-5D4BFA9A38A0}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DimMCC"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{381D4EA9-0320-4456-AA37-E963638FAFEF}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE DimMCC;&#xA;INSERT INTO DimMCC (mcc_code, mcc_description)&#xA;&#xA;SELECT &#xA;    &#xA;              mcc_code,&#xA;    &#xA;              TRIM(mcc_description)&#xA;&#xA;FROM FinancialStaging.dbo.stg_mcc_codes;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load DimMerchant"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{6FFAFD1B-7F51-466C-932C-AB08A7C4EDD9}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DimMerchant"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{381D4EA9-0320-4456-AA37-E963638FAFEF}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE DimMerchant;&#xA;INSERT INTO DimMerchant (merchant_id, mcc_sk, merchant_city, &#xA;    merchant_state, merchant_zip)&#xA;&#xA;SELECT DISTINCT &#xA;    &#xA;        TRIM(t.merchant_id), m.mcc_sk,&#xA;    TRIM(t.merchant_city),          TRIM(t.merchant_state), TRIM(t.zip)&#xA;&#xA;FROM FinancialStaging.dbo.stg_transactions t&#xA;&#xA;JOIN FinancialDW.dbo.DimMCC m &#xA;    &#xA;             ON CAST(TRIM(t.mcc) AS INT) = m.mcc_code&#xA;&#xA;WHERE t.merchant_id IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
